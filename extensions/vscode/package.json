{
  "name": "remote-codex-relay",
  "displayName": "Remote Codex Relay",
  "description": "Use Codex from your phone with a secure relay and explicit local approvals.",
  "version": "0.1.0",
  "publisher": "mmtmn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmtmn/remote-codex.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "extensionDependencies": [
    "openai.chatgpt"
  ],
  "keywords": [
    "codex",
    "openai",
    "relay",
    "mobile",
    "android"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remoteCodex.startSession",
        "title": "Remote Codex: Start Session",
        "category": "Remote Codex"
      },
      {
        "command": "remoteCodex.stopSession",
        "title": "Remote Codex: Stop Session",
        "category": "Remote Codex"
      },
      {
        "command": "remoteCodex.copyPairingLink",
        "title": "Remote Codex: Copy Pairing Link",
        "category": "Remote Codex"
      },
      {
        "command": "remoteCodex.reviewLatestPatch",
        "title": "Remote Codex: Review Latest Patch",
        "category": "Remote Codex"
      },
      {
        "command": "remoteCodex.openCodexSidebar",
        "title": "Remote Codex: Open Codex Sidebar",
        "category": "Remote Codex"
      },
      {
        "command": "remoteCodex.newCodexThread",
        "title": "Remote Codex: New Codex Thread",
        "category": "Remote Codex"
      },
      {
        "command": "remoteCodex.addSelectionToCodexThread",
        "title": "Remote Codex: Add Selection To Codex Thread",
        "category": "Remote Codex"
      },
      {
        "command": "remoteCodex.addFileToCodexThread",
        "title": "Remote Codex: Add Active File To Codex Thread",
        "category": "Remote Codex"
      }
    ],
    "configuration": {
      "title": "Remote Codex",
      "properties": {
        "remoteCodex.relayUrl": {
          "type": "string",
          "default": "ws://127.0.0.1:8787",
          "description": "Websocket URL the desktop extension itself uses to reach the relay."
        },
        "remoteCodex.mobileRelayUrl": {
          "type": "string",
          "default": "",
          "description": "Optional relay URL embedded into the phone pairing link. Leave empty to auto-derive a LAN URL from the desktop relay URL."
        },
        "remoteCodex.mobileUrl": {
          "type": "string",
          "default": "",
          "description": "Optional URL of the phone web client used for QR pairing. Leave empty to auto-derive a LAN URL on port 4173."
        },
        "remoteCodex.permissions.readWorkspace": {
          "type": "string",
          "enum": [
            "allow",
            "ask",
            "deny"
          ],
          "default": "allow",
          "description": "Whether the phone can read workspace snapshots, file previews, and git diffs."
        },
        "remoteCodex.permissions.runCodex": {
          "type": "string",
          "enum": [
            "allow",
            "ask",
            "deny"
          ],
          "default": "ask",
          "description": "Whether the phone can ask the desktop to run Codex in read-only planning mode."
        },
        "remoteCodex.permissions.runInspectionCommands": {
          "type": "string",
          "enum": [
            "allow",
            "ask",
            "deny"
          ],
          "default": "ask",
          "description": "Whether the phone can run allowlisted local inspection commands."
        },
        "remoteCodex.permissions.codexUi": {
          "type": "string",
          "enum": [
            "allow",
            "ask",
            "deny"
          ],
          "default": "ask",
          "description": "Whether the phone can trigger the installed OpenAI Codex UI commands in VS Code."
        },
        "remoteCodex.permissions.applyPatch": {
          "type": "string",
          "enum": [
            "allow",
            "ask",
            "deny"
          ],
          "default": "ask",
          "description": "Whether the phone can request a local patch review panel. Applying still requires a local button click."
        },
        "remoteCodex.commandAllowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "git status --short",
            "git diff --stat",
            "git diff --no-ext-diff"
          ],
          "description": "Exact local commands the phone may invoke. Commands must be simple executable-plus-args entries with no pipes or redirects."
        },
        "remoteCodex.codex.model": {
          "type": "string",
          "default": "",
          "description": "Optional model override passed to the local codex CLI."
        },
        "remoteCodex.codex.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional arguments forwarded to codex exec."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm build",
    "build": "tsup src/extension.ts --format cjs --external vscode",
    "watch": "tsup src/extension.ts --format cjs --watch --external vscode",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "package:vsix": "vsce package --no-dependencies --out ../../dist/remote-codex-relay.vsix",
    "install:local": "code --install-extension ../../dist/remote-codex-relay.vsix --force"
  },
  "dependencies": {
    "@remote-codex/protocol": "workspace:*",
    "qrcode": "^1.5.4",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.1",
    "@types/qrcode": "^1.5.5",
    "@types/vscode": "^1.96.0",
    "@types/ws": "^8.5.14"
  }
}
