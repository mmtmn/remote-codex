{
  "name": "remote-codex",
  "private": true,
  "version": "0.1.0",
  "description": "Secure phone relay for Codex and VS Code.",
  "bin": {
    "remote-codex": "./scripts/remote-codex.mjs"
  },
  "packageManager": "pnpm@10.28.1",
  "workspaces": [
    "apps/*",
    "extensions/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node ./scripts/remote-codex.mjs start",
    "start:watch": "node ./scripts/remote-codex.mjs start --watch",
    "stream": "node ./scripts/remote-codex.mjs stream",
    "stream:watch": "node ./scripts/remote-codex.mjs stream --watch",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "pnpm typecheck && pnpm test",
    "dev:relay": "pnpm --filter @remote-codex/relay-server dev",
    "dev:relay:watch": "pnpm --filter @remote-codex/relay-server dev:watch",
    "start:relay": "pnpm --filter @remote-codex/relay-server start",
    "dev:mobile": "pnpm --filter @remote-codex/mobile dev",
    "dev:mobile:watch": "pnpm --filter @remote-codex/mobile dev:watch",
    "dev:vscode": "pnpm --filter remote-codex-relay watch",
    "package:extension": "pnpm --filter remote-codex-relay package:vsix",
    "install:extension": "pnpm package:extension && pnpm --filter remote-codex-relay install:local",
    "doctor:linux-firewall": "bash ./scripts/check-linux-firewall.sh"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
